    "Enter the normal currency amount for one budget period. For example, enter 60000 for ₹60,000.": {
      "localizations": {
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "একটি বাজেট সময়ের সাধারণ মুদ্রার পরিমাণ লিখুন। উদাহরণ: ₹৬০,০০০ এর জন্য ৬০০০০ লিখুন।"
          }
        }
      }
    },
